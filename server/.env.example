# PrepWise Server — copy to .env and fill in values

NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/prepwise?retryWrites=true&w=majority

# JWT (use long random strings in production: openssl rand -base64 48)
JWT_SECRET=your_super_secret_jwt_key_change_me
JWT_REFRESH_SECRET=your_refresh_secret_change_me
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Frontend URL(s) for CORS — comma-separated for multiple (e.g. Vercel + custom domain)
CLIENT_URL=http://localhost:5173
CLIENT_URLS=http://localhost:5173,https://your-app.vercel.app

# Google AI Studio API key — https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Rate limiting (optional)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
