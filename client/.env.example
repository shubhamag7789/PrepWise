# PrepWise Client — copy to .env for local development

# Local dev — use Vite proxy (recommended; avoids CORS)
VITE_API_BASE_URL=/api/v1

# Or call the API directly (requires CORS on the server)
# VITE_API_BASE_URL=http://localhost:5000/api/v1

# Production: your Render API URL
# VITE_API_BASE_URL=https://prepwise-api.onrender.com/api/v1

VITE_APP_NAME=PrepWise
VITE_APP_VERSION=1.0.0
